{
  "name": "leludo",
  "version": "0.26.6",
  "description": "Ludo board game — browser + Android via Capacitor",
  "license": "GPL-3.0-or-later",
  "author": "Vishal Gidwani",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node tools/dev.mjs",
    "mp:server": "node src/server/local-server.mjs 8890",
    "soak": "node tools/soak/run.mjs",
    "soak:local": "node tools/soak/run.mjs --env=local",
    "soak:beta": "node tools/soak/run.mjs --env=beta",
    "cf:dev": "npx --yes wrangler dev",
    "cf:deploy": "npx --yes wrangler deploy",
    "cf:tail": "npx --yes wrangler tail",
    "cf:deploy:beta": "npx --yes wrangler deploy --env beta",
    "cf:tail:beta": "npx --yes wrangler tail --env beta",
    "test": "vitest",
    "test:run": "vitest run",
    "test:do": "vitest run --project workers",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:online": "node tools/clear-recordings.mjs && playwright test online-multiplayer-sessions --workers=2",
    "build:www": "node tools/build-www.mjs",
    "version:sync": "node tools/sync-android-version.mjs",
    "icons:generate": "node tools/generate-icons.mjs",
    "whatsnew:extract": "node tools/extract-whatsnew.mjs",
    "android:prepare": "npm run version:sync && npm run build:www && cap sync android",
    "android:open": "npm run android:prepare && cap open android",
    "android:run": "npm run android:prepare && cap run android"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@playwright/test": "1.60.0",
    "esbuild": "^0.28.1",
    "five-server": "^0.5.0",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.100.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  },
  "overrides": {
    "undici": "^7.28.0"
  }
}
